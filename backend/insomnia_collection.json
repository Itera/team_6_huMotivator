{
  "_type": "export",
  "export_format": 4,
  "export_source": "humotivatoren",
  "resources": [
    {
      "_id": "wrk_humotivatoren",
      "_type": "workspace",
      "name": "HuMotivatoren API",
      "description": "API-endepunkter for HuMotivatoren",
      "scope": "collection"
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_humotivatoren",
      "name": "Local",
      "data": {
        "base_url": "http://localhost:8000"
      }
    },
    {
      "_id": "fld_general",
      "_type": "request_group",
      "parentId": "wrk_humotivatoren",
      "name": "General"
    },
    {
      "_id": "req_root",
      "_type": "request",
      "parentId": "fld_general",
      "name": "Root",
      "method": "GET",
      "url": "{{ _.base_url }}/",
      "headers": []
    },
    {
      "_id": "req_health",
      "_type": "request",
      "parentId": "fld_general",
      "name": "Health Check",
      "method": "GET",
      "url": "{{ _.base_url }}/health",
      "headers": []
    },
    {
      "_id": "fld_llm",
      "_type": "request_group",
      "parentId": "wrk_humotivatoren",
      "name": "LLM"
    },
    {
      "_id": "req_models",
      "_type": "request",
      "parentId": "fld_llm",
      "name": "List Models",
      "method": "GET",
      "url": "{{ _.base_url }}/models",
      "headers": []
    },
    {
      "_id": "req_motivate",
      "_type": "request",
      "parentId": "fld_llm",
      "name": "Motivate",
      "method": "POST",
      "url": "{{ _.base_url }}/motivate",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"task\": \"Jeg skal lese nyhetene og trenger inspirasjon\",\n  \"model\": \"llama3.2\"\n}"
      }
    },
    {
      "_id": "req_poem",
      "_type": "request",
      "parentId": "fld_llm",
      "name": "Poem",
      "method": "POST",
      "url": "{{ _.base_url }}/poem",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"topic\": \"kaffe på kontoret\",\n  \"model\": \"llama3.2\"\n}"
      }
    }
  ]
}
